rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read and write to products, categories, banners, and settings.
    // This is required because client-side authentication is handled locally
    // and queries are run in an unauthenticated context.
    
    match /products/{productId} {
      allow read, write: if true;
    }
    
    match /categories/{categoryId} {
      allow read, write: if true;
    }
    
    match /banners/{bannerId} {
      allow read, write: if true;
    }
    
    match /settings/{settingId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /audit_logs/{logId} {
      allow read, write: if true;
    }

    match /ai_settings/{id} {
      allow read, write: if true;
    }

    match /prompt_versions/{id} {
      allow read, write: if true;
    }
  }
}
